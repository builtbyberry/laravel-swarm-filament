{
    "name": "builtbyberry/laravel-swarm-filament",
    "description": "Free, read-only Filament observability panel for Laravel Swarm — inspect swarm runs, steps, durable state, memory, streaming, and audit health from your app's Filament panel.",
    "keywords": ["laravel", "ai", "agents", "swarm", "filament", "observability"],
    "homepage": "https://swarm.builtbyberry.com",
    "support": {
        "docs": "https://swarm.builtbyberry.com",
        "issues": "https://github.com/builtbyberry/laravel-swarm-filament/issues",
        "source": "https://github.com/builtbyberry/laravel-swarm-filament"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Daniel Berry",
            "email": "daniel@jstreetdigital.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.5",
        "builtbyberry/laravel-swarm": "^0.19 || ^0.20",
        "filament/filament": "^5.0",
        "illuminate/contracts": "^13.0",
        "illuminate/support": "^13.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "larastan/larastan": "^3.10",
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^11.1",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "BuiltByBerry\\LaravelSwarmFilament\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BuiltByBerry\\LaravelSwarmFilament\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.2.x-dev"
        },
        "laravel": {
            "providers": [
                "BuiltByBerry\\LaravelSwarmFilament\\SwarmFilamentServiceProvider"
            ]
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse --memory-limit=2G --no-progress",
        "format": "vendor/bin/pint",
        "lint": "vendor/bin/pint --test",
        "test": "vendor/bin/pest tests/Feature"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
